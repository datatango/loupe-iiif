{
  "name": "loupe-iiif",
  "version": "1.0.1",
  "description": "",
  "main": "background.js",
  "scripts": {
    "build:validator": "node scripts/build-validator.js",
    "predev": "npm run build:validator",
    "dev": "vite",
    "prebuild": "npm run build:validator",
    "build": "vite build",
    "build:firefox": "TARGET=firefox npm run build",
    "package": "npm run build && cd dist && zip -r ../loupe-chrome-$npm_package_version.zip .",
    "package:firefox": "npm run build:firefox && cd dist && zip -r ../loupe-firefox-$npm_package_version.zip .",
    "build:icons": "for s in 16 32 48 64 96 128 256; do vips thumbnail assets/icon.svg public/icons/icon$s.png $s --height $s; done",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "pretest": "npm run build:validator",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datatango/loupe-iiif.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/datatango/loupe-iiif/issues"
  },
  "homepage": "https://github.com/datatango/loupe-iiif#readme",
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "ajv": "^8.20.0",
    "codemirror": "^6.0.2",
    "jsonc-parser": "^3.3.1"
  }
}
