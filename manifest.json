{
  "manifest_version": 3,

  "name": "Loupe - IIIF Presentation Validator",
  "version": "0.2.0",
  "description": "Check and validate IIIF Presentation Manifests.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "background": {
    "{{chrome}}.service_worker": "background.js",
    "{{firefox}}.scripts": ["background.js"]
  },
  "action": {
    "default_title": "open Loupe",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "64": "icons/icon64.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png",
      "256": "icons/icon256.png"
    }
  },
  "host_permissions": ["<all_urls>"],
  "{{firefox}}.browser_specific_settings": {
    "gecko": {
      "id": "loupe@datatango.dev",
      "strict_min_version": "115.0"
    }
  }
}
